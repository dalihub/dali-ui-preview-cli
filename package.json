{
  "name": "dali-ui-preview",
  "version": "0.1.0",
  "description": "CLI that renders Tizen DALi UI C++ to a PNG and emits a JSON node tree for humans and AI agents.",
  "bin": {
    "dali-ui-preview": "out/cli.js"
  },
  "main": "out/cli.js",
  "os": [
    "linux"
  ],
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run build",
    "test": "npm run test:unit",
    "test:unit": "c8 mocha out/test/unit/**/*.test.js --timeout 10000"
  },
  "dependencies": {
    "pngjs": "^7.0.0",
    "pixelmatch": "^7.1.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^20.0.0",
    "mocha": "^11.3.0",
    "c8": "^10.0.0",
    "chai": "^4.3.0",
    "sinon": "^17.0.0",
    "@types/mocha": "^10.0.0",
    "@types/chai": "^4.3.0",
    "@types/sinon": "^17.0.0",
    "@types/pngjs": "^6.0.5"
  }
}
